apiVersion: apps/v1
kind: Deployment
metadata:
  labels:
    app: tax-wisp-server
    version: v1
  name: tax-wisp-server
namespace:
	name: 
spec:
  progressDeadlineSeconds: 600
  replicas: 2
  revisionHistoryLimit: 10
  selector:
    matchLabels:
      app: tax-wisp-server
      version: v1
  template:
    metadata:
      labels:
        app: tax-wisp-server
        version: v1
    spec:
      containers:
      - args:
        - --spring.config.location=classpath:/application.yaml,file:/app/secret/application.yaml
        - --spring.profiles.active=prod
        command:
        - java
        - -jar
        - /app/tax-wisp-server.jar
        env:
        - name: NAMESPACE
          valueFrom:
            fieldRef:
              apiVersion: v1
              fieldPath: metadata.namespace
        image: nexus.smaitic.in/tax-wisp-server:2.13.2
        imagePullPolicy: Always
        name: server
        ports:
        - containerPort: 8080
          protocol: TCP
        resources:
          requests:
            memory: "256Mi"
            CPU:""
          limits:
            memory: "512Mi"
        livenessProbe:
          httpGet:
            path: /health
            port: 8080
          initialDelaySeconds: 5
          periodSeconds: 10
        readinessProbe:
          httpGet:
            path: /health
            port: 8080
          initialDelaySeconds: 2
          periodSeconds: 5
        volumeMounts:
        - mountPath: /app/secret/application.yaml
          name: tax-wisp-server
          readOnly: true
          subPath: application.yaml
      imagePullSecrets:
      - name: nexus-image-pull
      - name: nexus-snap-image-pull
      - name: nexus-prod-image-pull
      restartPolicy: Always
      schedulerName: default-scheduler
      securityContext: {}
      terminationGracePeriodSeconds: 30
      volumes:
      - csi:
          driver: secrets-store.csi.k8s.io
          readOnly: true
          volumeAttributes:
            secretProviderClass: tax-wisp-server
        name: tax-wisp-server
    nodeselector:
        labels:
            smaitic.com/role: production
    tolerations:
      - key: "smaitic.com/reserved-for"
        operator: "Equal"
        value: "production"
        effect: "NoSchedule"
 